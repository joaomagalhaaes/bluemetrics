generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  cpf                 String?       @unique
  phone               String?
  password            String
  avatarUrl           String?
  role                String        @default("user")     // user | admin
  suspended           Boolean       @default(false)
  adminApproved       Boolean       @default(false)      // admin pode liberar acesso manualmente
  onboardingCompleted Boolean       @default(false)
  createdAt           DateTime      @default(now())
  clients             Client[]
  whatsappInstances   WhatsappInstance[]
  leads               Lead[]
  appointments        Appointment[]
  subscription        Subscription?
}

model Client {
  id             String    @id @default(cuid())
  name           String
  adAccountId    String
  accessToken    String?
  appId          String?
  appSecret      String?
  tokenExpiresAt DateTime?
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  leads          Lead[]
}

model WhatsappInstance {
  id              String   @id @default(cuid())
  instanceName    String
  phone           String?
  status          String   @default("disconnected") // disconnected | connecting | connected
  qrCode          String?
  provider        String   @default("evolution")    // evolution | cloud_api
  phoneNumberId   String?  // Cloud API: ID do número no Meta
  waBusinessId    String?  // Cloud API: WhatsApp Business Account ID
  cloudApiToken   String?  // Cloud API: token permanente
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  leads           Lead[]
}

model Lead {
  id                String        @id @default(cuid())
  name              String?
  phone             String
  status            String        @default("new") // new | attending | closed | lost
  adSource          String?       // qual anúncio gerou
  adCampaign        String?
  notes             String?
  closedAt          DateTime?
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id])
  whatsappInstanceId String?
  whatsappInstance  WhatsappInstance? @relation(fields: [whatsappInstanceId], references: [id])
  conversations     Conversation[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Conversation {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromMe    Boolean  @default(false)
  message   String
  mediaUrl  String?
  timestamp DateTime @default(now())
}

model Appointment {
  id          String   @id @default(cuid())
  clientName  String
  service     String?
  value       Float
  date        DateTime
  notes       String?
  status      String   @default("scheduled") // scheduled | completed | cancelled
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               String    @default("trial") // trial | active | grace | suspended | cancelled
  plan                 String?   // monthly | annual
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  gracePeriodEnd       DateTime?
  suspendedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}
